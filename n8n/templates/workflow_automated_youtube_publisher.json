        "categoryId": "24",
        "privacyStatus": "public",
        "tags": "={{$json['Tags/Hashtags'].split(' ')}}",
        "videoFile": "/tmp/ani_dax_{{$json['Video Title'].replace(/[^a-zA-Z0-9]/g, '_')}}.mp4",
        "thumbnailFile": "/tmp/ani_dax_thumbnail_{{$json['Video Title'].replace(/[^a-zA-Z0-9]/g, '_')}}.jpg"
