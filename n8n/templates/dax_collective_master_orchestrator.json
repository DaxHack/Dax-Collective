    {
      "parameters": {
        "jsCode": "const brands = $input.all();\nconst currentHour = new Date().getHours();\n\nconst brandSchedules = {\n  'Dax the Traveler': { hours: [8, 14, 20], priority: 1 },\n  'God\\'s Vessel': { hours: [7, 12, 19], priority: 2 },\n  'Ani-Dax': { hours: [9, 15, 21], priority: 3 },\n  'Time-Zone Travelers': { hours: [10, 16, 22], priority: 4 }\n};\n\nconst activeBrands = [];\n\nfor (const brand of brands) {\n  const brandData = brand.json;\n  const brandName = brandData['Brand Name'];\n  const schedule = brandSchedules[brandName];\n  \n  if (!schedule) continue;\n  \n  const shouldPost = schedule.hours.includes(currentHour);\n  const isEnabled = brandData['Automation Status'] === 'Ready';\n  \n  if (shouldPost && isEnabled) {\n    activeBrands.push({\n      json: {\n        ...brandData,\n        priority: schedule.priority,\n        shouldTrigger: true,\n        triggerTime: new Date().toISOString()\n      }\n    });\n  }\n}\n\nactiveBrands.sort((a, b) => a.json.priority - b.json.priority);\n\nreturn activeBrands;"
      },
      "id": "content-prioritizer",
      "name": "Content Prioritizer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true
          },
          "conditions": [
            {
              "id": "condition1",
              "leftValue": "={{ $json['Brand Name'] }}",
              "rightValue": "Dax the Traveler",
              "operator": {
