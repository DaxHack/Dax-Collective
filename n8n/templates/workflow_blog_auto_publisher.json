    {
      "parameters": {
        "url": "https://graph.facebook.com/v18.0/me/feed",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "facebookGraphApi",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "🌍 New travel blog post is live!\n\n{{$('Publish Travel Blog').item.json.title}}\n\nDiscover survival tips, cultural insights, and travel hacks that could save your life on your next adventure.\n\n🎒 Join the Traveler's Club on Patreon for exclusive guides and insider tips!\n\n#travel #adventure #survival #backpacking"
            },
