    {
      "parameters": {
        "command": "rm /tmp/travel_blog_*.md /tmp/devotional_*.md 2>/dev/null || true"
      },
      "id": "14",
      "name": "Clean Up Processed Files",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2000,
        300
      ]
    },
    {
      "parameters": {
        "model": "deepseek-chat",
        "options": {
          "temperature": 0.7,
          "maxTokens": 300
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a content performance analyst. Predict blog performance and suggest optimization strategies."
            },
            {
              "role": "user",
              "content": "Analyze these published blog posts for performance potential:\n\nTravel: {{$('Publish Travel Blog').item.json.title || 'None'}}\nFaith: {{$('Publish Faith Blog').item.json.title || 'None'}}\n\nPredict:\n1. Traffic potential (1-10)\n2. Engagement likelihood\n3. Revenue generation potential\n4. SEO ranking probability\n5. Social sharing potential\n\nSuggest immediate optimization actions for maximum performance."
            }
          ]
        }
      },
      "id": "15",
      "name": "Analyze Blog Performance Potential",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
