      "parameters": {
        "jsCode": "// Determine voice based on content type and theological depth\nconst contentType = $json['Story Category'] || $json['Content Type'] || 'General';\nconst theologicalDepth = $json['Theological Depth'] || 'Intermediate';\nconst ageGroup = $json['Age Appropriateness'] || 'All ages';\n\nlet voiceId = 'WtA85syCrJwasGeHGH2p'; // Default comforting voice\n\n// Voice selection logic\nif (contentType.includes('Courage') || contentType.includes('Battle')) {\n  voiceId = 'ZF6FPAbjXT4488VcRRnw'; // Strong voice\n} else if (ageGroup.includes('Children') || ageGroup.includes('Families')) {\n  voiceId = 'WtA85syCrJwasGeHGH2p'; // Gentle voice\n} else if (theologicalDepth === 'Advanced' || contentType.includes('Teaching')) {\n  voiceId = 'ZF6FPAbjXT4488VcRRnw'; // Teaching voice\n}\n\nreturn {\n  json: {\n    ...($json),\n    selectedVoiceId: voiceId,\n    contentStyle: contentType,\n    targetAudience: ageGroup\n  }\n};"
      },
