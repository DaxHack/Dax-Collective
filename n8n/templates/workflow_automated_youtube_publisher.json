        "categoryId": "19",
        "privacyStatus": "public",
        "tags": "={{$json['Tags/Hashtags'].split(' ')}}",
        "videoFile": "/tmp/timezone_{{$json['Video Title'].replace(/[^a-zA-Z0-9]/g, '_')}}.mp4",
