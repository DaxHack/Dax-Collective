          "conditions": [
            {
              "id": "1",
              "leftValue": "={{$json.mimeType}}",
              "rightValue": "audio/",
              "operator": {
                "type": "string",
                "operation": "startsWith"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "5",
      "name": "Filter Audio Assets",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        680,
        400
      ]
    },
    {
      "parameters": {
        "model": "deepseek-chat",
        "options": {
          "temperature": 0.3,
          "maxTokens": 500
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an AI asset categorization expert. Analyze file names and organize digital assets into logical categories for content creation workflows."
            },
            {
              "role": "user",
              "content": "Categorize this image asset:\n\nFilename: {{$json.name}}\nSize: {{$json.size}} bytes\nModified: {{$json.modifiedTime}}\n\nDetermine:\n1. Brand category (Ani-Dax, Time-Zone Travelers, God's Vessel, or General)\n2. Content type (thumbnail, sticker, background, character, location, etc.)\n3. Usage recommendations\n4. Quality assessment\n5. Optimization suggestions\n6. Cross-brand potential\n\nProvide structured categorization for asset management."
            }
          ]
        }
      },
      "id": "6",
      "name": "Categorize Image Assets",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
      "position": [
        900,
        200
      ],
      "credentials": {
        "openAiApi": {
          "id": "2",
          "name": "DeepSeek API"
        }
      }
    },
