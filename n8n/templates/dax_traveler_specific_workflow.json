        "tags": "={{ JSON.parse($('Generate Travel Script').first().json.choices[0].message.content).tags.join(',') }},DaxTheTraveler,BudgetTravel",
        "categoryId": "19",
        "privacyStatus": "public",
        "binaryData": true,
        "binaryPropertyName": "data"
