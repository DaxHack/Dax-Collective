      "parameters": {
        "documentId": "={{$env.ASSET_MANAGEMENT_SHEET_ID}}",
        "sheetName": "Image Assets",
        "options": {
          "cellFormat": "USER_ENTERED",
          "useAppend": true
        },
        "fieldsUi": {
          "values": [
            {
              "column": "Asset Name",
              "fieldValue": "={{$('Filter Image Assets').item.json.name}}"
            },
            {
              "column": "File ID",
              "fieldValue": "={{$('Filter Image Assets').item.json.id}}"
            },
            {
              "column": "Size",
              "fieldValue": "={{$('Filter Image Assets').item.json.size}}"
            },
            {
              "column": "Modified Date",
              "fieldValue": "={{$('Filter Image Assets').item.json.modifiedTime}}"
            },
            {
              "column": "Drive Link",
              "fieldValue": "={{$('Filter Image Assets').item.json.webViewLink}}"
            },
            {
              "column": "AI Analysis",
              "fieldValue": "={{$json.choices[0].message.content}}"
            },
            {
              "column": "Last Scanned",
              "fieldValue": "={{$now.format('yyyy-MM-dd HH:mm')}}"
            }
          ]
        }
      },
