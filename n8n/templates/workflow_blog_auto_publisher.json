{
  "name": "Blog Auto Publisher",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      },
      "id": "1",
      "name": "Check Blog Content",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "path": "/tmp/",
        "fileExtension": "md"
      },
      "id": "2",
      "name": "Scan for Blog Files",
      "type": "n8n-nodes-base.readFile",
      "typeVersion": 1,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{$json.fileName}}",
              "rightValue": "travel_blog_",
              "operator": {
                "type": "string",
                "operation": "startsWith"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "3",
      "name": "Filter Travel Blogs",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        680,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{$json.fileName}}",
              "rightValue": "devotional_",
              "operator": {
                "type": "string",
                "operation": "startsWith"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "4",
      "name": "Filter Faith Blogs",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        680,
        400
      ]
    },
    {
      "parameters": {
        "model": "deepseek-chat",
        "options": {
          "temperature": 0.5,
          "maxTokens": 800
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a travel blog SEO expert. Optimize blog content for search engines while maintaining readability and engagement."
            },
            {
              "role": "user",
              "content": "Optimize this travel blog content for SEO:\n\n{{$json.data}}\n\nAdd:\n- SEO-optimized title and meta description\n- Strategic keyword placement\n- Internal linking suggestions\n- Call-to-action for Patreon Traveler's Club\n- Affiliate product recommendations\n- Social sharing optimization\n\nMaintain the authentic voice while maximizing search visibility."
            }
          ]
        }
      },
      "id": "5",
      "name": "SEO Optimize Travel Blog",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
      "position": [
        900,
        200
      ],
      "credentials": {
        "openAiApi": {
          "id": "2",
          "name": "DeepSeek API"
        }
      }
    },
    {
      "parameters": {
        "model": "deepseek-chat",
        "options": {
          "temperature": 0.4,
          "maxTokens": 600
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a Christian blog editor. Enhance devotional content for maximum spiritual impact and community engagement."
            },
            {
              "role": "user",
              "content": "Enhance this devotional blog for publication:\n\n{{$json.data}}\n\nAdd:\n- Compelling SEO title for faith-based searches\n- Meta description for Christian audience\n- Scripture cross-references\n- Discussion questions for community engagement\n- Prayer points\n- Call-to-action for God's Vessel merchandise\n- Social sharing for Christian community\n\nKeep the spiritual authenticity while optimizing for reach."
            }
          ]
        }
      },
      "id": "6",
      "name": "Enhance Faith Blog",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
      "position": [
        900,
        400
      ],
      "credentials": {
        "openAiApi": {
          "id": "2",
          "name": "DeepSeek API"
        }
      }
    },
    {
      "parameters": {
        "url": "https://api.wordpress.com/rest/v1.1/sites/{{$env.TRAVEL_BLOG_SITE_ID}}/posts/new",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "wordPressApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "={{$json.choices[0].message.content.split('\\n')[0].replace('# ', '')}}"
            },
            {
              "name": "content",
              "value": "={{$json.choices[0].message.content}}"
            },
            {
              "name": "status",
              "value": "publish"
            },
            {
              "name": "categories",
              "value": "Travel Tips,Adventure,Survival"
            },
            {
              "name": "tags",
              "value": "travel,adventure,survival,backpacking,tips"
            }
          ]
        }
      },
      "id": "7",
      "name": "Publish Travel Blog",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1120,
        200
      ],
      "credentials": {
        "wordPressApi": {
          "id": "13",
          "name": "Travel Blog WordPress"
        }
      }
    },
    {
      "parameters": {
        "url": "https://api.wordpress.com/rest/v1.1/sites/{{$env.FAITH_BLOG_SITE_ID}}/posts/new",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "wordPressApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
