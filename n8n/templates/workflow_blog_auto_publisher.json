    {
      "parameters": {
        "channel": "={{$env.DISCORD_CHANNEL_ID}}",
        "text": "📝 **BLOG CONTENT PUBLISHED!**\n\n**Travel Blog:** {{$('Publish Travel Blog').item.json.title || 'No travel content'}}\n**Faith Blog:** {{$('Publish Faith Blog').item.json.title || 'No faith content'}}\n\n**Published URLs:**\n🌍 Travel: {{$('Publish Travel Blog').item.json.URL || 'N/A'}}\n✝️ Faith: {{$('Publish Faith Blog').item.json.URL || 'N/A'}}\n\n**Social Media:**\n✅ Facebook posts shared\n✅ Twitter posts published\n✅ SEO optimized for search\n\n**Next Steps:**\n📊 Monitor blog traffic and engagement\n💰 Track affiliate link clicks\n🎯 Analyze conversion to Patreon\n📈 Optimize based on performance\n\n*Blog content is live and driving traffic!* 📈"
      },
