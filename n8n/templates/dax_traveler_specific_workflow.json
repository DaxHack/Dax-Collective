      "parameters": {
        "resource": "chat",
        "operation": "create",
        "model": "gpt-4-turbo-preview",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are Dax, an adventurous travel content creator. Create engaging travel scripts with personal storytelling, budget tips, and authentic experiences. Focus on {{ $json['Destination Focus'] || 'travel destinations' }} for {{ $json['Audience Segment'] || 'young adventurers' }}. Include practical advice, budget considerations ({{ $json['Budget Category'] || '$20-50/day' }}), and cultural insights. Return JSON: {\"script\": \"full narration with personal touch\", \"scenes\": [{\"timestamp\": \"0-15s\", \"visual_description\": \"travel scene description\", \"text_overlay\": \"key tip or location\"}], \"tags\": [\"travel hashtags\"], \"title\": \"engaging travel title\", \"description\": \"YouTube description with affiliate links\", \"patreon_cta\": \"Traveler's Club promotion\"}"
            },
            {
              "role": "user",
              "content": "Create a {{ $json['Video Length'] || '10-12 minute' }} travel video about: {{ $json['Script Prompt'] }}\\n\\nDestination: {{ $json['Destination Focus'] }}\\nBudget: {{ $json['Budget Category'] }}\\nSeason: {{ $json['Travel Season'] }}\\nAudience: {{ $json['Audience Segment'] }}\\nAffiliate Focus: {{ $json['Affiliate Link'] }}"
            }
          ]
        },
        "options": {
          "temperature": 0.8,
          "maxTokens": 2500
        }
      },
      "id": "generate-travel-script",
      "name": "Generate Travel Script",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [680, 300],
      "credentials": {
        "openAiApi": {
          "id": "openai-api",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "url": "https://fal.run/fal-ai/flux/schnell",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "falAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Key {{ $credentials.falAiApi.apiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "prompt",
              "value": "{{ $json['Destination Focus'] }}, travel photography, backpacking adventure, {{ $json['Travel Season'] }} season, budget travel, authentic local experience, vibrant colors, wanderlust, exploration"
            },
            {
              "name": "image_size",
              "value": "landscape_16_9"
            },
            {
              "name": "num_inference_steps",
              "value": 6
            },
            {
              "name": "enable_safety_checker",
              "value": true
            }
          ]
        },
        "options": {}
      },
      "id": "generate-travel-visual",
      "name": "Generate Travel Visual",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 200],
      "credentials": {
        "falAiApi": {
          "id": "fal-ai-api",
          "name": "Fal.AI API"
        }
      }
    },
    {
      "parameters": {
        "url": "https://api.elevenlabs.io/v1/text-to-speech/MINE",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "elevenLabsApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xi-api-key",
              "value": "{{ $credentials.elevenLabsApi.apiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "text",
              "value": "={{ JSON.parse($('Generate Travel Script').first().json.choices[0].message.content).script }}"
            },
            {
              "name": "model_id",
              "value": "eleven_multilingual_v2"
            },
            {
              "name": "voice_settings",
              "value": {
                "stability": 0.7,
                "similarity_boost": 0.8,
                "style": 0.4,
                "use_speaker_boost": true
              }
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "generate-dax-voiceover",
      "name": "Generate Dax Voiceover",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 400],
      "credentials": {
        "elevenLabsApi": {
          "id": "elevenlabs-api",
          "name": "ElevenLabs API"
