    {
      "parameters": {
        "jsCode": "const results = $input.all();\nconst analytics = {\n  totalVideosCreated: results.length,\n  brandPerformance: {},\n  timestamp: new Date().toISOString()\n};\n\nfor (const result of results) {\n  const brandName = result.json.brandName || 'Unknown';\n  if (!analytics.brandPerformance[brandName]) {\n    analytics.brandPerformance[brandName] = {\n      videosCreated: 0,\n      lastExecution: new Date().toISOString()\n    };\n  }\n  analytics.brandPerformance[brandName].videosCreated++;\n}\n\nreturn { json: analytics };"
      },
